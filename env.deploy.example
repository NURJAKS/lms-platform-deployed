# Скопируйте в .env.deploy в корне репозитория и подставьте значения:
#   cp env.deploy.example .env.deploy
#
# Используется только для docker compose --env-file .env.deploy -f docker-compose.vps.yml
# Файл .env.deploy в git не коммитьте.

# Обязательно смените (например: openssl rand -hex 32)
SECRET_KEY=replace_with_long_random_string

# Все origin'ы браузера, с которых идут запросы к API (через запятую, без пробелов)
# Пример с IP VPS:
# ALLOWED_ORIGINS=http://203.0.113.10:3000,http://localhost:3000
# Пример с доменом и HTTPS:
ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000

# Публичный URL фронта (ссылки в письмах и редиректах)
FRONTEND_PUBLIC_URL=https://app.example.com

# Опционально — без ключей ИИ-чат работает в демо-режиме
OPENAI_API_KEY=
GEMINI_API_KEY=
