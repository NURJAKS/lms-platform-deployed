DATABASE_URL=postgresql://postgres:postgres@localhost:5432/education_platform
SECRET_KEY=your-secret-key-change-in-production
OPENAI_API_KEY=sk-your-openai-api-key
# Альтернатива OpenAI — Gemini (приоритет, если задан)
GEMINI_API_KEY=
UPLOAD_DIR=./uploads
# Цена Premium в тенге
PREMIUM_PRICE_TENGE=199999

# Google OAuth (вход через Google). Client ID тот же, что NEXT_PUBLIC_GOOGLE_CLIENT_ID во frontend.
GOOGLE_CLIENT_ID=

# CORS: через запятую все origin фронта (тот же список добавляйте в Google OAuth Authorized JavaScript origins).
# Продакшен: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# SMTP настройки для Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true